<div class="container">
  <h1>Gerador de pauta de reunião</h1>
  <p class="subtitle">Preencha os campos e gere uma pauta estruturada em segundos.</p>

  <div class="fields">
    <div>
      <label for="tema">Tema / objetivo da reunião</label>
      <input id="tema" type="text" placeholder="Ex: alinhamento semanal de fraude logística" />
    </div>

    <div class="row">
      <div>
        <label for="participantes">Participantes</label>
        <input id="participantes" type="text" placeholder="Ex: time de analytics, Lucas" />
      </div>
      <div>
        <label for="duracao">Duração</label>
        <select id="duracao">
          <option>30 min</option>
          <option selected>45 min</option>
          <option>1 hora</option>
          <option>1h30</option>
          <option>2 horas</option>
        </select>
      </div>
    </div>

    <div>
      <label for="contexto">Contexto adicional (opcional)</label>
      <textarea id="contexto" placeholder="Ex: última reunião decidimos X, há pendências em Y..."></textarea>
    </div>
  </div>

  <button class="primary" id="btn" onclick="gerar()">Gerar pauta ↗</button>

  <div class="resultado" id="resultado">
    <div class="resultado-header">
      <span>Pauta gerada</span>
      <button class="secondary" onclick="copiar()" id="copiar-btn">Copiar</button>
    </div>
    <div id="saida"></div>
  </div>

  <div class="erro" id="erro">Algo deu errado. Verifique sua chave de API e tente novamente.</div>
</div>

<script>
const API_KEY = 'SUA_CHAVE_AQUI';

async function gerar() {
  const tema = document.getElementById('tema').value.trim();
  if (!tema) { document.getElementById('tema').focus(); return; }

  const participantes = document.getElementById('participantes').value.trim();
  const duracao = document.getElementById('duracao').value;
  const contexto = document.getElementById('contexto').value.trim();

  const btn = document.getElementById('btn');
  btn.textContent = 'Gerando...';
  btn.disabled = true;

  document.getElementById('resultado').style.display = 'none';
  document.getElementById('erro').style.display = 'none';
  document.getElementById('saida').textContent = '';

  const prompt = `Crie uma pauta de reunião clara e objetiva em português com as seguintes informações:

Tema/objetivo: ${tema}
${participantes ? `Participantes: ${participantes}` : ''}
Duração: ${duracao}
${contexto ? `Contexto: ${contexto}` : ''}

Formate assim:
- Título da reunião
- Data/hora: [a definir]
- Duração: ${duracao}
- Objetivo: (1 frase)
- Tópicos com tempo estimado para cada um
- Decisões esperadas
- Próximos passos

Seja direto e prático. Sem introduções longas.`;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': API_KEY,
        'anthropic-version': '2023-06-01'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    const data = await res.json();
    const texto = data.content?.map(b => b.text || '').join('') || '';
    if (!texto) throw new Error('empty');

    document.getElementById('saida').textContent = texto;
    document.getElementById('resultado').style.display = 'block';
  } catch {
    document.getElementById('erro').style.display = 'block';
  } finally {
    btn.textContent = 'Gerar pauta ↗';
    btn.disabled = false;
  }
}

function copiar() {
  const texto = document.getElementById('saida').textContent;
  navigator.clipboard.writeText(texto).then(() => {
    const btn = document.getElementById('copiar-btn');
    btn.textContent = 'Copiado!';
    setTimeout(() => btn.textContent = 'Copiar', 2000);
  });
}
</script>
